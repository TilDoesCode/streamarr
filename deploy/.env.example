# The release bundle pins this to its own version. Use :latest only if you
# deliberately want `docker compose pull` to track every stable release.
STREAMARR_IMAGE=ghcr.io/tildoescode/streamarr:latest

# Generate unique values, for example:
#   openssl rand -base64 32
STREAMARR_ADMIN_USERNAME=admin
STREAMARR_ADMIN_PASSWORD=
STREAMARR_API_KEY=

# Optional HTTP proxy for Newznab searches, capability tests, and NZB retrieval only.
# Example when a Gluetun service shares this Compose network and enables HTTPPROXY:
# INDEXER_PROXY=http://gluetun:8888
INDEXER_PROXY=

# Safe default for a reverse proxy on the same machine. To reach the services
# directly from your LAN, change to 0.0.0.0 and rely on a trusted LAN/firewall.
STREAMARR_BIND_ADDRESS=127.0.0.1
STREAMARR_PORT=8080
JELLYFIN_BIND_ADDRESS=127.0.0.1
JELLYFIN_PORT=8096

# If a reverse proxy reaches Streamarr from a non-loopback address, uncomment
# COMPOSE_FILE and set the proxy's exact source IP plus browser-visible origin.
# COMPOSE_FILE=compose.yml:compose.proxy.yml
STREAMARR_TRUSTED_PROXY=
STREAMARR_TRUSTED_ORIGIN=

# Used only by the optional bundled Jellyfin profile. On Linux these should
# normally match the owner of this directory (`id -u` and `id -g`).
JELLYFIN_UID=1000
JELLYFIN_GID=1000
