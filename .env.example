# Copy this file to .env and provide unique, randomly generated values before
# starting the Compose stack. Empty values intentionally make Compose fail fast.
STREAMARR_ADMIN_USERNAME=admin
STREAMARR_ADMIN_PASSWORD=
STREAMARR_API_KEY=

# Required for semantic catalog search, canonical metadata, and artwork. Accepts either
# the short v3 API key or the API Read Access Token (JWT). You may instead enter it after
# startup under Settings -> General. Example language: de-DE.
TMDB_API_KEY=
TMDB_LANGUAGE=

# The dev stack binds these ports to loopback only.
STREAMARR_PORT=8080
JELLYFIN_PORT=8096
STREAMARR_WEB_PORT=5173

# Keep these aligned with the host users that own the bind-mounted source/build output.
# On Linux, use `id -u` / `id -g` when your account is not 1000:1000.
PLUGIN_TFM=net9.0
JELLYFIN_UID=1000
JELLYFIN_GID=1000
WEB_UID=1000
WEB_GID=1000
